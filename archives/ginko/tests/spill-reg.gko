# this tests the abilty of the compielr to handle an infset-ime amount of registers via
# stack allocation and livetime analysis

(fun main ()
	(set-im $exit 0)
	(set-im $v1 101)
	(set-im $v2 102)
	(set-im $v3 103)
	(set-im $v4 104)
	(set-im $v5 105)
