import ./stdlib/print.lang;

# expected stdout:
# 1.5
# 42.25
# 123.456
# 1.5
# 1.5
# 42.25
# 123.456
# 42.25
# 123.438
# 500
# 500
# 99

fun main() i32 {
	var f16_val : f16 = 1.5f16;
	var f32_val : f32 = 42.25f32;
	var f64_val : f64 = 123.456f64;

	print_f16(f16_val);
	print_f32(f32_val);
	print_f64(f64_val);

	# Widening
	var w1 : f32 = f16_val as f32;
	print_f32(w1);

	var w2 : f64 = f16_val as f64;
	print_f64(w2);

	var w3 : f64 = f32_val as f64;
	print_f64(w3);

	# Narrowing
	var n1 : f32 = f64_val as f32;
	print_f32(n1);

	var n2 : f16 = f32_val as f16;
	print_f16(n2);

	var n3 : f16 = f64_val as f16;
	print_f16(n3);

	# Integer zu Float
	var i_val : i32 = 500i32;
	var c1 : f32 = i_val as f32;
	print_f32(c1);

	var c2 : f64 = i_val as f64;
	print_f64(c2);

	# Float zu Integer
	var f_trunc : f32 = 99.99f32;
	var c3 : i32 = f_trunc as i32;
	print_i32(c3);

	0
};